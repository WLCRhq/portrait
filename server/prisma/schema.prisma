generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  googleId     String     @unique
  email        String     @unique
  name         String
  role         String     @default("user")
  accessToken  String
  refreshToken String
  createdAt    DateTime   @default(now())
  decks        Deck[]
  proposals    Proposal[]
}

model Deck {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  googleId     String
  title        String
  slideCount   Int       @default(0)
  exportedAt   DateTime?
  exportStatus String    @default("pending")
  bgColor      String?
  createdAt    DateTime  @default(now())
  slides       Slide[]
  links        ShareLink[]
  proposals    Proposal[]
}

model Slide {
  id        String         @id @default(cuid())
  deckId    String
  deck      Deck           @relation(fields: [deckId], references: [id], onDelete: Cascade)
  index     Int
  imageUrl  String
  createdAt DateTime       @default(now())
  overlays  SlideOverlay[]

  @@unique([deckId, index])
}

model SlideOverlay {
  id         String @id @default(cuid())
  slideId    String
  slide      Slide  @relation(fields: [slideId], references: [id], onDelete: Cascade)
  imageUrl   String
  x          Float
  y          Float
  width      Float
  height     Float
  zIndex     Int    @default(0)
  cropTop    Float  @default(0)
  cropBottom Float  @default(0)
  cropLeft   Float  @default(0)
  cropRight  Float  @default(0)
}

model ShareLink {
  id         String       @id @default(cuid())
  deckId     String?
  deck       Deck?        @relation(fields: [deckId], references: [id], onDelete: Cascade)
  proposalId String?
  proposal   Proposal?    @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  slug       String       @unique
  label      String?
  active     Boolean      @default(true)
  createdAt  DateTime     @default(now())
  expiresAt  DateTime?
  sessions   ViewSession[]
}

model ViewSession {
  id           String       @id @default(cuid())
  linkId       String
  link         ShareLink    @relation(fields: [linkId], references: [id], onDelete: Cascade)
  viewerIp     String
  userAgent    String
  country      String?
  region       String?
  city         String?
  timezone     String?
  isp          String?
  browser      String?
  os           String?
  device       String?
  screenRes    String?
  referrer     String?
  startedAt    DateTime     @default(now())
  endedAt      DateTime?
  totalSeconds Int?
  events       SlideEvent[]
}

model SlideEvent {
  id         String      @id @default(cuid())
  sessionId  String
  session    ViewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  slideIndex Int
  enteredAt  DateTime
  exitedAt   DateTime?
  durationMs Int?
}

model Proposal {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  title     String
  client    String?
  deckId    String?
  deck      Deck?           @relation(fields: [deckId], references: [id])
  sowMeta   Json?
  sowData   Json?
  status    String          @default("draft")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  slides    ProposalSlide[]
  links     ShareLink[]
}

model ProposalSlide {
  id              String   @id @default(cuid())
  proposalId      String
  proposal        Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  index           Int
  type            String
  sourceSlideIndex Int?
  sowCategoryId   String?
  content         Json?
  createdAt       DateTime @default(now())

  @@unique([proposalId, index])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  targetId  String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
